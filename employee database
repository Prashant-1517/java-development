SELECT employee_id, first_name, last_name, email
FROM employees
WHERE email NOT LIKE '%@%.%' 
   OR email LIKE '% %'; -- Catches spaces inside emails
   
SELECT employee_id, first_name, last_name, hire_date, termination_date
FROM employees
WHERE termination_date IS NOT NULL 
  AND termination_date < hire_date;
  
SELECT employee_id, first_name, last_name, job_title, salary
FROM employees
WHERE salary <= 0 
   OR salary IS NULL;
   
SELECT e.employee_id, e.first_name, e.last_name, e.manager_id
FROM employees e
WHERE e.manager_id IS NOT NULL 
  AND e.manager_id NOT IN (SELECT employee_id FROM employees);
  
  SELECT 
    department,
    COUNT(employee_id) AS staff_count,       -- Row count per department
    MIN(salary) AS department_min_salary,     -- Minimum salary in this department
    MAX(hire_date) AS most_recent_hire        -- Latest hire in this department
FROM employees
GROUP BY department
ORDER BY staff_count DESC;                    -- Organizes output by largest department first

SELECT employee_id, first_name, last_name, department, salary
FROM employees
WHERE salary = (SELECT MIN(salary) FROM employees);

SELECT employee_id, first_name, last_name, department, hire_date
FROM employees
WHERE hire_date = (SELECT MAX(hire_date) FROM employees);


