CREATE TABLE employees (
    employee_id INT PRIMARY KEY,
    first_name VARCHAR(50) NOT NULL,
    last_name VARCHAR(50) NOT NULL,
    email VARCHAR(100) UNIQUE, -- Validation: Prevents duplicate emails
    hire_date DATE NOT NULL,
    job_title VARCHAR(50) NOT NULL,
    department VARCHAR(50) NOT NULL,
    salary DECIMAL(10, 2) CHECK (salary > 0), -- Validation: Salary must be positive
    manager_id INT,
    termination_date DATE,
    -- Validation: Ensures termination happens AFTER hiring
    CONSTRAINT chk_term_date CHECK (termination_date IS NULL OR termination_date >= hire_date)
);


